.page-index { padding: 24rpx 24rpx 120rpx; min-height: 100vh; box-sizing: border-box; }
.welcome-card { text-align: center; padding: 80rpx 48rpx; margin-top: 60rpx; }
.welcome-emoji { font-size: 120rpx; margin-bottom: 24rpx; }
.welcome-title { font-size: 44rpx; font-weight: 700; margin-bottom: 16rpx; }
.welcome-desc { font-size: 28rpx; color: var(--text-secondary); margin-bottom: 48rpx; line-height: 1.8; }
.welcome-actions { padding: 0 40rpx; }
.family-overview { padding: 32rpx; }
.family-name { font-size: 36rpx; font-weight: 700; margin-bottom: 28rpx; text-align: center; }
.members-steps { justify-content: center; gap: 40rpx; flex-wrap: wrap; }
.member-ring { display: flex; flex-direction: column; align-items: center; min-width: 120rpx; }
.ring-wrapper { position: relative; width: 120rpx; height: 120rpx; }
.ring-canvas { width: 120rpx; height: 120rpx; position: absolute; top: 0; left: 0; }
.member-avatar { width: 80rpx; height: 80rpx; border-radius: 50%; position: absolute; top: 20rpx; left: 20rpx; }
.member-name { font-size: 24rpx; color: var(--text-secondary); margin-top: 8rpx; max-width: 120rpx; overflow: hidden; text-overflow: ellipsis; white-space: nowrap; }
.member-steps-num { font-size: 22rpx; color: var(--primary); font-weight: 600; }
.family-total { padding-top: 20rpx; border-top: 1rpx solid var(--border); }
.coin-banner { padding: 24rpx 32rpx; background: linear-gradient(135deg, #FFF8E1, #FFFFFF); }
.coin-icon { font-size: 48rpx; }
.coin-badge { background: var(--coin); color: #7B5800; font-size: 28rpx; font-weight: 700; padding: 8rpx 20rpx; border-radius: 24rpx; }
.coin-color { color: #E6A800; }
.feed-section { margin-top: 16rpx; }
.section-title { padding: 16rpx 8rpx; font-size: 32rpx; }
.feed-item { padding: 28rpx 32rpx; }
.feed-header { margin-bottom: 16rpx; }
.feed-nickname { font-size: 30rpx; }
.feed-time { font-size: 24rpx; }
.feed-tag { font-size: 22rpx; padding: 4rpx 16rpx; border-radius: 16rpx; background: #FFF3E8; color: var(--primary); }
.feed-tag-reward { background: #FFF8E1; color: #E6A800; }
.feed-tag-exercise { background: #E8F5E9; color: #4CAF50; }
.feed-checkin-data { background: var(--bg); border-radius: 16rpx; padding: 20rpx 24rpx; margin-bottom: 16rpx; gap: 48rpx; }
.checkin-stat { display: flex; align-items: baseline; gap: 6rpx; }
.stat-num { font-size: 44rpx; font-weight: 700; color: var(--primary); }
.stat-label { font-size: 24rpx; color: var(--text-secondary); }
.feed-mood { margin-bottom: 12rpx; }
.mood-tag { font-size: 26rpx; background: #FFF3E8; padding: 6rpx 16rpx; border-radius: 12rpx; color: var(--primary); }
.feed-content { font-size: 30rpx; line-height: 1.8; margin-bottom: 16rpx; word-break: break-all; }
.feed-images { display: flex; flex-wrap: wrap; gap: 12rpx; margin-bottom: 16rpx; }
.feed-img-single { width: 100%; max-height: 400rpx; border-radius: 16rpx; }
.feed-img-multi { width: calc(33.33% - 8rpx); height: 200rpx; border-radius: 12rpx; }
.feed-actions { padding-top: 12rpx; gap: 32rpx; }
.action-btn { gap: 8rpx; font-size: 28rpx; padding: 8rpx 16rpx; border-radius: 24rpx; color: var(--text-secondary); }
.action-btn:active { background: var(--bg); }
.action-btn.liked { color: #FF4757; }
.action-count { font-size: 24rpx; }
.feed-comments { padding-top: 4rpx; }
.comment-item { font-size: 26rpx; line-height: 1.8; padding: 4rpx 0; }
.comment-name { font-weight: 600; }
.comment-input-mask { position: fixed; top: 0; left: 0; right: 0; bottom: 0; background: rgba(0,0,0,0.3); z-index: 100; }
.comment-input-bar { position: fixed; bottom: 0; left: 0; right: 0; background: #FFF; padding: 16rpx 24rpx; padding-bottom: calc(16rpx + env(safe-area-inset-bottom)); display: flex; align-items: center; gap: 16rpx; z-index: 101; box-shadow: 0 -4rpx 16rpx rgba(0,0,0,0.08); transform: translateY(100%); transition: transform 0.3s ease; }
.comment-input-bar.show { transform: translateY(0); }
.comment-input { flex: 1; background: var(--bg); border-radius: 36rpx; padding: 16rpx 28rpx; font-size: 30rpx; }
.comment-send-btn { background: var(--primary) !important; color: #FFF !important; font-size: 28rpx !important; padding: 12rpx 32rpx !important; border-radius: 36rpx !important; line-height: 1.4 !important; min-height: auto !important; }
.load-more { padding: 32rpx 0; }

/* 排行榜 */
.ranking-card { padding: 24rpx 32rpx; }
.ranking-list { }
.ranking-item { padding: 16rpx 0; border-bottom: 1rpx solid var(--border); align-items: center; }
.ranking-item:last-child { border-bottom: none; }
.ranking-item.ranking-first { }
.ranking-pos { width: 48rpx; text-align: center; }
.ranking-medal { font-size: 36rpx; }
.ranking-num { font-size: 28rpx; color: var(--text-secondary); font-weight: 600; }
.ranking-avatar { width: 56rpx; height: 56rpx; border-radius: 50%; margin-left: 16rpx; }
.ranking-name { font-size: 30rpx; }
.ranking-steps { font-size: 28rpx; color: var(--text-secondary); font-weight: 600; }
.ranking-steps-first { color: #E6A800; font-size: 32rpx; }
