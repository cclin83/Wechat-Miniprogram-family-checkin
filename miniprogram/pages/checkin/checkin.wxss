.page-checkin { padding: 24rpx 24rpx 120rpx; min-height: 100vh; box-sizing: border-box; }
.steps-hero { text-align: center; padding: 48rpx 32rpx; }
.steps-ring-big { position: relative; width: 360rpx; height: 360rpx; margin: 0 auto; }
.steps-ring-canvas { width: 360rpx; height: 360rpx; }
.steps-center { position: absolute; top: 50%; left: 50%; transform: translate(-50%,-50%); text-align: center; width: 240rpx; z-index: 10; }
.steps-number { font-size: 48rpx; font-weight: 800; color: var(--primary); line-height: 1; overflow: visible; white-space: nowrap; }
.steps-label { font-size: 28rpx; color: var(--text-secondary); margin-top: 4rpx; }
.steps-targets { padding: 24rpx 16rpx; background: var(--bg); border-radius: 16rpx; }
.target-item { display: flex; flex-direction: column; align-items: center; gap: 6rpx; opacity: 0.4; transition: opacity 0.3s; }
.target-item.reached { opacity: 1; }
.target-coin-badge { display: inline-flex; align-items: center; justify-content: center; width: 48rpx; height: 48rpx; border-radius: 50%; background: linear-gradient(135deg, #FFD54F, #FFB300); color: #FFF; font-size: 28rpx; font-weight: 800; box-shadow: 0 2rpx 8rpx rgba(255,179,0,0.3); }
.target-item.reached .target-coin-badge { background: linear-gradient(135deg, #FF8C42, #E07030); }
.target-text { font-size: 24rpx; color: var(--text-secondary); }
.target-coin { font-size: 22rpx; color: var(--primary); font-weight: 600; }
.sync-btn { width: 80% !important; margin: 0 auto; }
.checkin-post { padding: 32rpx; }
.mood-tags { flex-wrap: wrap; gap: 16rpx; }
.mood-item { font-size: 26rpx; padding: 10rpx 20rpx; background: var(--bg); border-radius: 24rpx; border: 2rpx solid transparent; }
.mood-item.selected { background: #FFF3E8; border-color: var(--primary); color: var(--primary); }
.post-textarea { width: 100%; min-height: 160rpx; background: var(--bg); border-radius: 16rpx; padding: 20rpx 24rpx; font-size: 30rpx; line-height: 1.8; box-sizing: border-box; }
.post-images { gap: 16rpx; flex-wrap: wrap; }
.img-item { position: relative; width: 180rpx; height: 180rpx; }
.uploaded-img { width: 100%; height: 100%; border-radius: 12rpx; }
.img-delete { position: absolute; top: -12rpx; right: -12rpx; width: 40rpx; height: 40rpx; background: rgba(0,0,0,0.5); color: #FFF; border-radius: 50%; display: flex; align-items: center; justify-content: center; font-size: 22rpx; }
.img-add { width: 180rpx; height: 180rpx; background: var(--bg); border: 2rpx dashed var(--border); border-radius: 12rpx; display: flex; flex-direction: column; align-items: center; justify-content: center; gap: 8rpx; }
.img-add-icon { font-size: 48rpx; } .img-add-text { font-size: 22rpx; color: var(--text-secondary); }
.checkin-btn { width: 100% !important; }
.not-reached { padding: 48rpx 32rpx; }
.encourage-emoji { font-size: 80rpx; }
.calendar-section { padding: 32rpx; }
.calendar-header { margin-bottom: 24rpx; }
.calendar-arrow { font-size: 28rpx; color: var(--text-secondary); padding: 8rpx 16rpx; }
.calendar-title { font-size: 32rpx; font-weight: 600; margin: 0 16rpx; }
.streak-badge { font-size: 24rpx; background: #FFF3E8; color: var(--primary); padding: 6rpx 16rpx; border-radius: 16rpx; font-weight: 600; }
.calendar-weekdays { justify-content: space-around; margin-bottom: 12rpx; }
.weekday { width: calc(100%/7); text-align: center; font-size: 24rpx; color: var(--text-secondary); }
.calendar-grid { display: flex; flex-wrap: wrap; }
.calendar-day { width: calc(100%/7); height: 72rpx; display: flex; flex-direction: column; align-items: center; justify-content: center; font-size: 28rpx; position: relative; }
.calendar-day.empty { visibility: hidden; }
.calendar-day.today { color: var(--primary); font-weight: 700; }
.calendar-day.checked { color: var(--success); font-weight: 600; }
.day-dot { width: 10rpx; height: 10rpx; background: var(--success); border-radius: 50%; position: absolute; bottom: 4rpx; }
.month-stats { padding-top: 24rpx; border-top: 1rpx solid var(--border); }
.stat-block { display: flex; flex-direction: column; align-items: center; gap: 4rpx; }
.stat-value { font-size: 40rpx; font-weight: 700; color: var(--primary); }
.stat-desc { font-size: 22rpx; color: var(--text-secondary); }
