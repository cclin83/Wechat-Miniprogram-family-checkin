<view class="page-shop {{largeText ? 'large-text' : ''}}">
  <view class="coin-header card">
    <view class="coin-balance flex-row">
      <text class="coin-big-icon">🪙</text>
      <view class="ml-sm"><view class="text-sm text-secondary">我的家庭币</view><view class="coin-amount">{{userCoins}}</view></view>
    </view>
  </view>

  <!-- 心愿卡区域 -->
  <view class="wish-section">
    <view class="section-title flex-between mb-md">
      <text class="text-bold">心愿卡</text>
      <text class="text-sm text-secondary">{{wishCost}}币/张</text>
    </view>
    <view class="wish-make-card card" bindtap="showWishModal">
      <view class="wish-make-inner flex-row">
        <text class="wish-make-icon">🌟</text>
        <view class="ml-sm flex-1">
          <view class="text-bold">许个心愿</view>
          <view class="text-sm text-secondary">花{{wishCost}}币许下一个心愿</view>
        </view>
        <view class="wish-price-btn" wx:if="{{isAdmin}}" catchtap="showWishPriceSetting">设置价格</view>
      </view>
    </view>
    <view wx:if="{{wishes.length > 0}}">
      <view class="wish-card card {{item.status === 'fulfilled' ? 'wish-fulfilled' : 'wish-pending'}}" wx:for="{{wishes}}" wx:key="_id">
        <view class="wish-card-top flex-row">
          <text class="wish-status-icon">{{item.status === 'fulfilled' ? '✅' : '🌟'}}</text>
          <view class="flex-1 ml-sm">
            <view class="text-bold">{{item.content}}</view>
            <view class="text-sm text-secondary">{{item.nickName}} · {{item.status === 'fulfilled' ? '已实现' : '等待实现'}}</view>
          </view>
        </view>
        <view wx:if="{{item.status === 'fulfilled'}}" class="wish-fulfilled-info mt-sm">
          <text class="text-sm text-secondary">{{item.fulfilledNickName || '家人'}} 实现了这个心愿</text>
          <view wx:if="{{item.fulfilledPhoto}}" class="wish-photo-link" bindtap="viewWishPhoto" data-index="{{index}}">
            <text class="text-sm text-primary">查看照片</text>
          </view>
        </view>
        <view wx:if="{{item.status === 'pending' && (item.openid !== openid || isAdmin)}}" class="wish-fulfill-actions flex-row mt-sm">
          <view class="wish-fulfill-btn flex-1" bindtap="fulfillWish" data-index="{{index}}">拍照实现</view>
          <view class="wish-fulfill-btn-text flex-1" bindtap="fulfillWishDirect" data-index="{{index}}">直接标记完成</view>
        </view>
        <view wx:if="{{item.status === 'pending' && item.openid === openid && !isAdmin}}" class="text-sm text-secondary mt-sm">等待家人实现...</view>
      </view>
    </view>
    <view class="empty-hint text-sm text-secondary" wx:if="{{wishes.length === 0}}">还没有心愿卡</view>
  </view>

  <!-- 奖品区域 -->
  <view class="add-reward-bar flex-between card" wx:if="{{isAdmin}}">
    <view><view class="text-bold">管理奖品</view><view class="text-sm text-secondary">为家人设置温暖的奖励</view></view>
    <button class="btn-secondary" bindtap="showAddReward">+ 添加</button>
  </view>
  <view class="reward-section">
    <view class="section-title text-bold mb-md">可兑换奖品</view>
    <view class="empty-state" wx:if="{{rewards.length === 0}}">
      <view class="empty-icon">🎁</view><view>还没有奖品</view>
      <view class="text-sm text-secondary mt-sm" wx:if="{{isAdmin}}">点击上方"添加"设置奖品吧</view>
      <view class="text-sm text-secondary mt-sm" wx:else>等管理员设置奖品哦</view>
    </view>
    <view class="reward-card card" wx:for="{{rewards}}" wx:key="_id">
      <view class="reward-top flex-row" bindtap="onRewardTap" data-index="{{index}}">
        <view class="reward-type-icon">
          <text wx:if="{{item.type === 'photo'}}">📸</text><text wx:elif="{{item.type === 'voice'}}">🎤</text>
          <text wx:elif="{{item.type === 'video'}}">🎬</text><text wx:else>💌</text>
        </view>
        <view class="flex-1 ml-sm"><view class="reward-name text-bold">{{item.name}}</view><view class="reward-desc text-sm text-secondary">{{item.description}}</view></view>
        <view class="reward-price"><text class="price-num">{{item.coinsNeeded}}</text><text class="price-unit">币</text></view>
      </view>
      <view class="reward-preview mt-sm" wx:if="{{isAdmin && item.type === 'voice'}}" bindtap="playRewardVoice" data-url="{{item.mediaUrl}}"><text class="preview-btn">▶️ 试听</text></view>
      <view class="reward-preview mt-sm" wx:if="{{isAdmin && item.type === 'video' && item.mediaUrl}}"><video class="reward-video" src="{{item.mediaUrl}}" controls></video></view>
      <view class="reward-preview mt-sm" wx:if="{{isAdmin && item.type === 'photo' && item.mediaUrl}}"><image class="reward-image" src="{{item.mediaUrl}}" mode="widthFix" bindtap="previewRewardImage" data-url="{{item.mediaUrl}}"></image></view>
      <view class="reward-bottom mt-md">
        <view class="text-sm text-secondary mb-sm">剩余 {{item.stock - (item.redeemed || 0)}} / {{item.stock}}</view>
        <view wx:if="{{item.redeemedByMe}}" class="redeem-btn redeemed" bindtap="viewReward" data-index="{{index}}">查看奖品</view>
        <view wx:elif="{{(item.redeemed || 0) >= item.stock}}" class="redeem-btn disabled">已兑完</view>
        <view wx:elif="{{userCoins >= item.coinsNeeded}}" class="redeem-btn" bindtap="onRedeem" data-index="{{index}}" data-id="{{item._id}}">兑换</view>
        <view wx:else class="redeem-btn disabled">金币不足</view>
      </view>
      <view class="admin-actions flex-row mt-sm" wx:if="{{isAdmin}}">
        <text class="admin-btn" bindtap="editReward" data-index="{{index}}">编辑</text>
        <text class="admin-btn danger" bindtap="deleteReward" data-index="{{index}}" data-id="{{item._id}}">删除</text>
      </view>
    </view>
  </view>

  <!-- 许心愿弹窗 -->
  <view class="modal-mask" wx:if="{{showWishModal}}" catchtap="hideWishModal"></view>
  <view class="wish-modal-panel" wx:if="{{showWishModal}}">
    <view class="modal-header flex-between"><text class="text-bold text-lg">许个心愿</text><text class="modal-close" bindtap="hideWishModal">✕</text></view>
    <view class="wish-modal-body">
      <view class="text-sm text-secondary mb-md">选择一个心愿，或自己写：</view>
      <view class="wish-template-list">
        <view class="wish-template-item {{wishContent === item ? 'selected' : ''}}" wx:for="{{wishTemplates}}" wx:key="*this" bindtap="selectWishTemplate" data-text="{{item}}">{{item}}</view>
      </view>
      <textarea class="wish-input" placeholder="或者写下你的心愿..." value="{{wishContent}}" bindinput="onWishInput" maxlength="50"></textarea>
      <view class="wish-cost-info flex-between mt-md">
        <text class="text-sm text-secondary">花费</text>
        <text class="text-bold" style="color:#E6A800;">{{wishCost}} 🪙</text>
      </view>
    </view>
    <view class="modal-footer">
      <view class="redeem-btn {{userCoins >= wishCost && wishContent ? '' : 'disabled'}}" bindtap="submitWish">{{userCoins >= wishCost ? '许愿' : '金币不足'}}</view>
    </view>
  </view>

  <!-- 心愿卡价格设置弹窗 -->
  <view class="modal-mask" wx:if="{{showWishPriceModal}}" catchtap="hideWishPriceModal"></view>
  <view class="wish-modal-panel" wx:if="{{showWishPriceModal}}">
    <view class="modal-header flex-between"><text class="text-bold text-lg">设置心愿卡价格</text><text class="modal-close" bindtap="hideWishPriceModal">✕</text></view>
    <view class="wish-modal-body">
      <view class="form-group"><text class="form-label">每张心愿卡所需家庭币</text><input class="form-input" type="number" value="{{wishPriceInput}}" bindinput="onWishPriceInput" placeholder="输入价格"/></view>
    </view>
    <view class="modal-footer"><view class="redeem-btn" bindtap="saveWishPrice">保存</view></view>
  </view>

  <!-- 编辑奖品弹窗 -->
  <view class="modal-mask" wx:if="{{showModal}}" catchtap="hideModal"></view>
  <view class="modal-panel {{showModal ? 'show' : ''}}" wx:if="{{showModal}}">
    <view class="modal-header flex-between"><text class="text-bold text-lg">{{editingReward ? '编辑奖品' : '添加奖品'}}</text><text class="modal-close" bindtap="hideModal">✕</text></view>
    <scroll-view scroll-y class="modal-body">
      <view class="form-group"><text class="form-label">奖品名称</text><input class="form-input" placeholder="例如：宝宝的一张照片" value="{{formName}}" bindinput="onFormInput" data-field="formName"/></view>
      <view class="form-group"><text class="form-label">描述（可选）</text><input class="form-input" placeholder="简单描述一下这个奖品" value="{{formDesc}}" bindinput="onFormInput" data-field="formDesc"/></view>
      <view class="form-group"><text class="form-label">所需金币</text><input class="form-input" type="number" placeholder="例如：30" value="{{formCoins}}" bindinput="onFormInput" data-field="formCoins"/></view>
      <view class="form-group"><text class="form-label">奖品类型</text>
        <view class="type-options flex-row">
          <view class="type-option {{formType === 'photo' ? 'selected' : ''}}" bindtap="selectType" data-type="photo">📸 照片</view>
          <view class="type-option {{formType === 'voice' ? 'selected' : ''}}" bindtap="selectType" data-type="voice">🎤 语音</view>
          <view class="type-option {{formType === 'text' ? 'selected' : ''}}" bindtap="selectType" data-type="text">💌 文字</view>
          <view class="type-option {{formType === 'video' ? 'selected' : ''}}" bindtap="selectType" data-type="video">🎬 视频</view>
        </view>
      </view>
      <view class="form-group" wx:if="{{formType === 'text'}}"><text class="form-label">文字内容</text><textarea class="form-textarea" placeholder="写一段鼓励的话..." value="{{formTextContent}}" bindinput="onFormInput" data-field="formTextContent"></textarea></view>
      <view class="form-group" wx:if="{{formType === 'photo' || formType === 'video'}}"><text class="form-label">上传{{formType === 'photo' ? '照片' : '视频'}}</text>
        <view class="upload-area" bindtap="uploadMedia">
          <image wx:if="{{formMediaUrl}}" class="upload-preview" src="{{formMediaUrl}}" mode="aspectFill"></image>
          <view wx:else class="upload-placeholder"><text class="upload-icon">+</text><text class="upload-text">点击上传</text></view>
        </view>
      </view>
      <view class="form-group"><text class="form-label">可兑换次数</text><input class="form-input" type="number" placeholder="例如：1" value="{{formStock}}" bindinput="onFormInput" data-field="formStock"/></view>
    </scroll-view>
    <view class="modal-footer"><button class="btn-primary" bindtap="saveReward" loading="{{saving}}">{{saving ? '保存中...' : '保存'}}</button></view>
  </view>

  <!-- 兑换成功弹窗 -->
  <view class="modal-mask" wx:if="{{showRedeemSuccess}}" bindtap="hideRedeemSuccess"></view>
  <view class="redeem-success-panel {{showRedeemSuccess ? 'show' : ''}}" wx:if="{{showRedeemSuccess}}">
    <view class="success-animation">🎉</view><view class="success-title">兑换成功！</view><view class="success-reward-name">{{redeemedReward.name}}</view>
    <view class="success-content" wx:if="{{redeemedReward.type === 'text'}}"><view class="success-text-content">{{redeemedReward.textContent}}</view></view>
    <view class="success-content" wx:if="{{redeemedReward.type === 'photo'}}"><image class="success-image" src="{{redeemedReward.mediaUrl}}" mode="widthFix"></image></view>
    <view class="success-content" wx:if="{{redeemedReward.type === 'voice'}}"><view class="success-voice-btn" bindtap="playRedeemVoice">▶️ 播放语音</view></view>
    <view class="success-content" wx:if="{{redeemedReward.type === 'video'}}"><video class="success-video" src="{{redeemedReward.mediaUrl}}" controls autoplay></video></view>
    <button class="btn-primary mt-lg" bindtap="hideRedeemSuccess">太棒了</button>
  </view>
</view>
